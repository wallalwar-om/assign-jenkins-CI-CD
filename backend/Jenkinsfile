pipeline {
    agent any

    environment {
        PATH = "/home/ubuntu/.nvm/versions/node/v24.14.1/bin:${env.PATH}"
    }

    stages {

        stage('Pull Latest Code') {
            steps {
                sh 'git -C /home/ubuntu/project pull origin main'
            }
        }

        stage('Install Dependencies') {
            steps {
                sh '''
                    python3 -m venv /home/ubuntu/project/backend/.venv
                    /home/ubuntu/project/backend/.venv/bin/pip install --upgrade pip
                    /home/ubuntu/project/backend/.venv/bin/pip install -r /home/ubuntu/project/backend/requirements.txt
                '''
            }
        }

        stage('Run Tests') {
            steps {
                sh '''
                    /home/ubuntu/project/backend/.venv/bin/pip install pytest --quiet
                    /home/ubuntu/project/backend/.venv/bin/pytest /home/ubuntu/project/backend/tests/ -v || true
                '''
            }
        }

        stage('Restart Application') {
    steps {
        sh '''
            sudo -u ubuntu bash -c "
                cd /home/ubuntu/project/backend &&
                pm2 delete flask-backend || true &&
                pm2 start app.py --name flask-backend --interpreter /home/ubuntu/project/backend/.venv/bin/python &&
                pm2 save
            "
        '''
    }
}
    }

    post {
        success { echo '✅ Flask backend deployed successfully!' }
        failure { echo '❌ Flask backend deployment FAILED.' }
    }
}
