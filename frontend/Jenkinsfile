pipeline {
    agent any
    environment {
        PATH         = "/home/ubuntu/.nvm/versions/node/v24.14.1/bin:${env.PATH}"
        APP_DIR      = '/home/ubuntu/project/frontend'
        APP_PORT     = '3000'
        PM2_APP_NAME = 'express-frontend'
    }
    stages {
        stage('Pull Latest Code') {
            steps {
                sh 'git -C /home/ubuntu/project pull origin main'
            }
        }
        stage('Install Dependencies') {
            steps {
                sh '''
                    echo ">>> Installing Node.js dependencies..."
                    npm install --prefix /home/ubuntu/project/frontend
                '''
            }
        }
        stage('Run Tests') {
            steps {
                sh '''
                    echo ">>> Running tests..."
                    if grep -q '"test"' /home/ubuntu/project/frontend/package.json; then
                        npm test --prefix /home/ubuntu/project/frontend -- --forceExit || true
                    else
                        echo "No test script defined in package.json — skipping."
                    fi
                '''
            }
        }
        stage('Restart Application') {
            steps {
                sh '''
                    sudo -u ubuntu bash -c "
                        cd /home/ubuntu/project/frontend &&
                        pm2 delete ${PM2_APP_NAME} || true &&
                        pm2 start app.js --name ${PM2_APP_NAME} &&
                        pm2 save
                    "
                '''
            }
        }
    }
    post {
        success { echo '✅ Express frontend deployed successfully!' }
        failure { echo '❌ Express frontend deployment FAILED.' }
    }
}
